# ⚠️ Jamais de vraie valeur dans ce fichier ni dans le dépôt.
# Les secrets se collent directement dans Vercel (Settings → Environment Variables)
# et dans un .env local non commité.

# PostgreSQL Neon (région UE — Francfort) : https://console.neon.tech
DATABASE_URL=

# Stripe (compte de la nouvelle entité — Q4) : https://dashboard.stripe.com/apikeys
# MODE TEST d'abord : clés sk_test_… / pk_test_… uniquement.
# Empreinte carte au dépôt (SetupIntent, 0 € débité) puis débit off-session
# au choix du pet sitter (Q14). Sans ces clés, le site fonctionne en mode
# dégradé : dépôt OK, paiement annoncé « très prochainement ».
STRIPE_SECRET_KEY=
# Clé publique (navigateur) — même page que la clé secrète :
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook : https://dashboard.stripe.com/test/webhooks → endpoint
# https://<domaine>/api/webhooks/stripe — événements : setup_intent.succeeded,
# payment_intent.succeeded, payment_intent.payment_failed.
STRIPE_WEBHOOK_SECRET=

# ─── Authentification (Auth.js v5, lien magique e-mail) ───
# Secret de signature des jetons — générer avec : npx auth secret (ou openssl rand -base64 32)
AUTH_SECRET=
# URL canonique de l'app. RECOMMANDÉ EN PRODUCTION (durcissement audit §7) :
# fige l'hôte des liens magiques et neutralise l'empoisonnement du header Host.
# Ex. https://www.allopetsitter.fr (ou l'URL Vercel en attendant le domaine).
AUTH_URL=
# Sur Vercel, l'hôte de la requête fait foi (trustHost est déjà activé dans
# src/lib/auth.ts) — AUTH_TRUST_HOST=true n'est donc pas nécessaire.

# Envoi des e-mails de connexion via l'API HTTP Resend : https://resend.com/api-keys
# Sans clé : en local le lien s'affiche dans les logs serveur ; en production
# la connexion est refusée proprement (aucun lien loggué).
RESEND_API_KEY=
# Expéditeur. TANT QUE allopetsitter.fr n'est pas acheté ET vérifié dans
# Resend (https://resend.com/domains), utiliser l'adresse de test Resend :
#   EMAIL_FROM=AlloPetsitter <onboarding@resend.dev>
# (en mode test, Resend ne délivre qu'à l'adresse du compte Resend lui-même).
# Une fois le domaine vérifié : "AlloPetsitter <connexion@allopetsitter.fr>".
EMAIL_FROM=

# ─── Stockage privé du contrôle d'identité (Vercel Blob) ───
# Pièce d'identité + selfie des pet sitters, en accès PRIVÉ. À créer dans
# Vercel → Storage → Blob (https://vercel.com/dashboard/stores), puis
# « Connect Project » injecte automatiquement BLOB_READ_WRITE_TOKEN.
# Sans ce token : le site tourne, la vérification s'affiche « bientôt
# disponible » (aucune dépendance du build à ce token).
# ⚠️ RGPD : les fichiers sont supprimés dès la décision de l'administrateur.
BLOB_READ_WRITE_TOKEN=
